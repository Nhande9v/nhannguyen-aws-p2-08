# Terraform local directories
**/.terraform/*
.terraform/

# Terraform state files contain infrastructure details and can contain sensitive values
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Terraform variable files can contain secrets
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan
*.plan
plan.out

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# SSH keys and certificates
*.pem
*.key
*.crt
key-pair/
certs/

# Local logs and temporary files
*.log
*.tmp
*.bak
*.swp
*~

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

